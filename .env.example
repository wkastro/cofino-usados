# Database
DATABASE_URL="mysql://user:password@localhost:3306/cofino_usados"
# NextAuth
NEXTAUTH_SECRET="genera-un-secret-seguro-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/
AUTH_GOOGLE_ID="xxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-xxxx"

# Apple Sign-In — https://developer.apple.com/
# AUTH_APPLE_SECRET es un JWT firmado con tu clave privada .p8
# Válido máx. 6 meses. Ver: https://authjs.dev/guides/configuring-apple
AUTH_APPLE_ID="com.tuapp.serviceid"
AUTH_APPLE_SECRET="eyJhbGciOiJFUzI1NiIsImtpZCI6..."

# Admin Seed
ADMIN_EMAIL="admin@cofino.com"
ADMIN_PASSWORD="AdminPass123"
ADMIN_FULL_NAME="Administrador Cofiño"

# AWS S3 / LightSail Object Storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-2"
AWS_BUCKET_NAME=""
NEXT_PUBLIC_AWS_BASE_URL=""
